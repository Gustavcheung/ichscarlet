import numpy as np
import matplotlib.pyplot as plt
from matplotlib import animation
from IPython.display import HTML, display
import ipywidgets as widgets
from mpl_toolkits.mplot3d import Axes3D
import time

# Set up the figure and 3D axis
fig = plt.figure(figsize=(12, 8))
ax = fig.add_subplot(111, projection='3d')

# Simulation parameters
t_max = 10  # maximum simulation time
dt = 0.05   # time step
n_frames = int(t_max / dt)

# Colors
GROUND_COLOR = 'saddlebrown'
INCOMING_COLOR = 'red'
INTERCEPTOR_COLOR = 'blue'
EXPLOSION_COLOR = 'orange'
TRAIL_COLOR = 'gray'

# Create ground (a simple plane)
x_ground = np.linspace(-10, 10, 20)
y_ground = np.linspace(-10, 10, 20)
X_ground, Y_ground = np.meshgrid(x_ground, y_ground)
Z_ground = np.zeros_like(X_ground)

# Initialize trajectories
def init_trajectories():
    # Incoming missile: starts high, targets ground near origin
    incoming_start = np.array([8, 5, 15])
    incoming_target = np.array([2, 1, 0])
    
    # Interceptor: launches from ground near origin
    interceptor_start = np.array([-3, -2, 0])
    
    # Calculate direction vectors
    incoming_dir = incoming_target - incoming_start
    incoming_dir = incoming_dir / np.linalg.norm(incoming_dir)
    
    # Interceptor aims to intercept at some point
    intercept_time = 4.5  # time when interception should occur
    intercept_point = incoming_start + incoming_dir * 7  # estimated intercept point
    
    interceptor_dir = intercept_point - interceptor_start
    interceptor_dir = interceptor_dir / np.linalg.norm(interceptor_dir)
    
    # Speeds
    v_incoming = 2.0
    v_interceptor = 3.0
    
    # Generate trajectories
    t = np.arange(0, t_max, dt)
    incoming_traj = []
    interceptor_traj = []
    
    for time in t:
        # Incoming missile position
        incoming_pos = incoming_start + incoming_dir * v_incoming * time
        # Stop at ground
        if incoming_pos[2] < 0:
            incoming_pos[2] = 0
        incoming_traj.append(incoming_pos)
        
        # Interceptor missile position
        interceptor_pos = interceptor_start + interceptor_dir * v_interceptor * time
        # Keep above ground
        if interceptor_pos[2] < 0:
            interceptor_pos[2] = 0
        interceptor_traj.append(interceptor_pos)
    
    return np.array(incoming_traj), np.array(interceptor_traj), intercept_time

# Initialize trajectories
incoming_traj, interceptor_traj, intercept_time = init_trajectories()

# Calculate explosion point (where missiles are closest)
def find_explosion_point():
    min_dist = float('inf')
    explosion_frame = 0
    
    for i in range(len(incoming_traj)):
        dist = np.linalg.norm(incoming_traj[i] - interceptor_traj[i])
        if dist < min_dist:
            min_dist = dist
            explosion_frame = i
    
    return explosion_frame, min_dist

explosion_frame, min_dist = find_explosion_point()
explosion_pos = incoming_traj[explosion_frame]

# Animation function
def animate(frame):
    ax.clear()
    
    # Set labels and title
    ax.set_xlabel('X (km)')
    ax.set_ylabel('Y (km)')
    ax.set_zlabel('Z (km)')
    ax.set_title(f'Missile Defense Simulation - Frame {frame}/{n_frames}')
    
    # Set axis limits
    ax.set_xlim(-10, 10)
    ax.set_ylim(-10, 10)
    ax.set_zlim(0, 20)
    
    # Plot ground
    ax.plot_surface(X_ground, Y_ground, Z_ground, alpha=0.3, color=GROUND_COLOR)
    
    # Plot city/target area
    ax.scatter([2, 1], [1, -1], [0, 0], color='green', s=100, marker='^', label='Targets')
    
    # Plot trajectories up to current frame
    if frame > 0:
        # Incoming missile trail
        ax.plot(incoming_traj[:frame, 0], 
                incoming_traj[:frame, 1], 
                incoming_traj[:frame, 2], 
                color=INCOMING_COLOR, alpha=0.3, linewidth=1, label='Incoming trail')
        
        # Interceptor missile trail
        ax.plot(interceptor_traj[:frame, 0], 
                interceptor_traj[:frame, 1], 
                interceptor_traj[:frame, 2], 
                color=INTERCEPTOR_COLOR, alpha=0.3, linewidth=1, label='Interceptor trail')
    
    # Plot current positions
    if frame < len(incoming_traj):
        # Incoming missile
        if frame < explosion_frame:
            ax.scatter(incoming_traj[frame, 0], 
                      incoming_traj[frame, 1], 
                      incoming_traj[frame, 2], 
                      color=INCOMING_COLOR, s=200, marker='o', label='Incoming Missile')
            
            # Interceptor missile
            ax.scatter(interceptor_traj[frame, 0], 
                      interceptor_traj[frame, 1], 
                      interceptor_traj[frame, 2], 
                      color=INTERCEPTOR_COLOR, s=200, marker='^', label='Interceptor')
            
            # Draw line between missiles (for visual effect)
            if frame > explosion_frame - 10:
                ax.plot([incoming_traj[frame, 0], interceptor_traj[frame, 0]],
                       [incoming_traj[frame, 1], interceptor_traj[frame, 1]],
                       [incoming_traj[frame, 2], interceptor_traj[frame, 2]],
                       color='yellow', linestyle='--', alpha=0.5)
        
        # Explosion effect
        elif frame >= explosion_frame and frame < explosion_frame + 15:
            # Draw explosion
            explosion_size = 100 + (frame - explosion_frame) * 50
            ax.scatter(explosion_pos[0], explosion_pos[1], explosion_pos[2], 
                      color=EXPLOSION_COLOR, s=explosion_size, alpha=0.7, marker='*', label='EXPLOSION!')
            
            # Draw explosion debris
            for i in range(5):
                offset = (frame - explosion_frame) * 0.1
                ax.scatter(explosion_pos[0] + np.sin(i*2) * offset,
                          explosion_pos[1] + np.cos(i*2) * offset,
                          explosion_pos[2] + np.sin(i*3) * offset,
                          color='yellow', s=50, alpha=0.5)
    
    # Add legend
    ax.legend(loc='upper right')
    
    # Add text information
    if frame < explosion_frame:
        distance = np.linalg.norm(incoming_traj[frame] - interceptor_traj[frame])
        ax.text2D(0.02, 0.98, f'Distance: {distance:.2f} km', 
                 transform=ax.transAxes, fontsize=12, verticalalignment='top',
                 bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
    
    ax.view_init(elev=20, azim=frame/2)  # Rotate view for better 3D effect

# Create animation
print("Creating animation...")
anim = animation.FuncAnimation(fig, animate, frames=n_frames, interval=50, repeat=True)

# Display in Colab
plt.close()  # Prevent duplicate display
html_video = anim.to_html5_video()
display(HTML(html_video))

# Print simulation info
print(f"\nSimulation Statistics:")
print(f"Interception occurred at frame: {explosion_frame}")
print(f"Minimum distance between missiles: {min_dist:.2f} km")
print(f"Explosion position: ({explosion_pos[0]:.1f}, {explosion_pos[1]:.1f}, {explosion_pos[2]:.1f}) km")

# Create an interactive version with widgets
print("\n" + "="*50)
print("Interactive Control Panel")
print("="*50)

# Interactive function
def interactive_simulation(launch_angle=45, interceptor_speed=3.0, intercept_height=5):
    # Recalculate trajectories based on parameters
    incoming_start = np.array([8, 5, 15])
    incoming_target = np.array([2, 1, 0])
    interceptor_start = np.array([-3, -2, 0])
    
    # Calculate directions
    incoming_dir = incoming_target - incoming_start
    incoming_dir = incoming_dir / np.linalg.norm(incoming_dir)
    
    # Adjust interceptor based on parameters
    angle_rad = np.radians(launch_angle)
    intercept_point = np.array([2, 1, intercept_height])
    
    interceptor_dir = intercept_point - interceptor_start
    interceptor_dir = interceptor_dir / np.linalg.norm(interceptor_dir)
    
    # Speeds
    v_incoming = 2.0
    v_interceptor = interceptor_speed
    
    # Generate trajectories
    t = np.arange(0, t_max, dt)
    incoming_traj = []
    interceptor_traj = []
    
    for time in t:
        incoming_pos = incoming_start + incoming_dir * v_incoming * time
        if incoming_pos[2] < 0:
            incoming_pos[2] = 0
        incoming_traj.append(incoming_pos)
        
        interceptor_pos = interceptor_start + interceptor_dir * v_interceptor * time
        if interceptor_pos[2] < 0:
            interceptor_pos[2] = 0
        interceptor_traj.append(interceptor_pos)
    
    incoming_traj = np.array(incoming_traj)
    interceptor_traj = np.array(interceptor_traj)
    
    # Find closest approach
    min_dist = float('inf')
    explosion_frame = 0
    for i in range(len(incoming_traj)):
        dist = np.linalg.norm(incoming_traj[i] - interceptor_traj[i])
        if dist < min_dist:
            min_dist = dist
            explosion_frame = i
    
    # Create new figure
    fig2 = plt.figure(figsize=(10, 8))
    ax2 = fig2.add_subplot(111, projection='3d')
    
    # Plot everything
    ax2.plot_surface(X_ground, Y_ground, Z_ground, alpha=0.3, color=GROUND_COLOR)
    ax2.scatter([2, 1], [1, -1], [0, 0], color='green', s=100, marker='^')
    
    # Plot trajectories
    ax2.plot(incoming_traj[:, 0], incoming_traj[:, 1], incoming_traj[:, 2], 
             color=INCOMING_COLOR, linewidth=2, label='Incoming Missile')
    ax2.plot(interceptor_traj[:, 0], interceptor_traj[:, 1], interceptor_traj[:, 2], 
             color=INTERCEPTOR_COLOR, linewidth=2, label='Interceptor')
    
    # Mark explosion
    if explosion_frame < len(incoming_traj):
        ax2.scatter(incoming_traj[explosion_frame, 0], 
                   incoming_traj[explosion_frame, 1], 
                   incoming_traj[explosion_frame, 2], 
                   color=EXPLOSION_COLOR, s=300, marker='*', label='Interception Point')
    
    ax2.set_xlabel('X (km)')
    ax2.set_ylabel('Y (km)')
    ax2.set_zlabel('Z (km)')
    ax2.set_title(f'Missile Defense - Interception at height {incoming_traj[explosion_frame, 2]:.1f} km')
    ax2.set_xlim(-10, 10)
    ax2.set_ylim(-10, 10)
    ax2.set_zlim(0, 20)
    ax2.legend()
    ax2.view_init(elev=20, azim=45)
    
    plt.show()
    
    print(f"Minimum distance: {min_dist:.2f} km")
    print(f"Interception height: {incoming_traj[explosion_frame, 2]:.1f} km")

# Create interactive widgets
print("\nAdjust parameters to see different interception scenarios:")
interactive_plot = widgets.interactive(interactive_simulation, 
                                       launch_angle=widgets.IntSlider(min=0, max=90, step=5, value=45, description='Launch Angle:'),
                                       interceptor_speed=widgets.FloatSlider(min=1.0, max=5.0, step=0.2, value=3.0, description='Interceptor Speed:'),
                                       intercept_height=widgets.FloatSlider(min=1, max=15, step=1, value=5, description='Target Height:'))

display(interactive_plot)
